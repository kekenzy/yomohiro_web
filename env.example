# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-lightsail-ip

# Database (本番環境ではPostgreSQLを推奨)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Security
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# django-allauth の OAuth redirect_uri が https になるよう強制（本番で DEBUG=True の誤設定時は必須）
# ローカルで http のみの LINE コールバックなら http
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

# Email settings (開発環境ではコンソールバックエンドを使用)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- 本番: AWS（Amazon SES）の SMTP を使う例（Lightsail / EC2 など同一リージョン推奨）---
# SES で「SMTP 認証情報」を作成し、検証済みドメインまたは検証済みメールから送信する。
# ホストはリージョンで変わる: email-smtp.<リージョン>.amazonaws.com
# 例: 東京 ap-northeast-1 → email-smtp.ap-northeast-1.amazonaws.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.ap-northeast-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=（SES の SMTP ユーザー名。IAM とは別に SES コンソールで発行）
# EMAIL_HOST_PASSWORD=（SES の SMTP パスワード）
# DEFAULT_FROM_EMAIL=noreply@検証済みドメイン.example.com
# SERVER_EMAIL=noreply@検証済みドメイン.example.com

# --- 本番: Gmail 等の SMTP の例（参考）---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@example.com
# SERVER_EMAIL=noreply@example.com
# 会員登録完了時に管理者へ通知する宛先（カンマ区切り）。未設定ならスーパーユーザーのメールへ
# REGISTRATION_NOTIFY_EMAILS=admin@example.com,ops@example.com

# Square API settings
# True にすると決済リンク・Webhook が有効（本番で Square を使うとき）
SQUARE_INTEGRATION_ENABLED=False
SQUARE_APPLICATION_ID=sandbox-sq0idb-Klqy4yYEmO_5_1Ea9msc3w
SQUARE_ACCESS_TOKEN=EAAAl5UHQGekKNOWGRkLWMJ7NTohmkFaFRZXL2wioazmvTMi-PcFmU9SHpwwdSSe

# SQUARE_ENVIRONMENT: Square APIの環境を指定
# - sandbox: 開発・テスト環境（テスト用の決済が可能、実際の決済は発生しない）
# - production: 本番環境（実際の決済が発生する）
# 開発時は "sandbox"、本番環境では "production" を設定
SQUARE_ENVIRONMENT=sandbox

# SQUARE_LOCATION_ID: SquareのロケーションID（オプション）
# Square Developer Portalで取得可能。特定のロケーションで決済を行う場合に設定
SQUARE_LOCATION_ID=LHQHHBA22J5E1

# SQUARE_WEBHOOK_SECRET: Webhook署名検証用のシークレット（本番環境では必須）
# Square Developer Portal > Webhooks > 署名キー で取得
# 開発環境では空でも動作するが、セキュリティ上設定を推奨
# 本番環境では必ず設定してください（Webhookの改ざん防止のため）
SQUARE_WEBHOOK_SECRET=

# LINE Login（django-allauth）— 両方とも空ならログイン画面に LINE ボタンは出ない
# LINE Developers の「LINE Login」チャネルから取得
# コールバック URL（コンソールに登録）: https://YOUR_DOMAIN/accounts/line/login/callback/
# ローカル例: http://127.0.0.1:8000/accounts/line/login/callback/（Docker Compose はポート 8001 など）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# メール取得は LINE コンソールで OpenID Connect のメール申請が「Applied」になるまで付けない: profile,openid
# LINE_LOGIN_SCOPE=profile,openid,email

